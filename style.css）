* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial;
}

body {
    background: #f5f7fb;
}

/* 导航 */
header {
    display: flex;
    justify-content: space-between;
    padding: 20px 60px;
    background: #fff;
}

nav a {
    margin: 0 15px;
    text-decoration: none;
    color: #333;
}

.btn {
    background: #2b6cff;
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
}

/* 主区域 */
.hero {
    display: flex;
    align-items: center;
    padding: 80px;
}

.hero-text {
    flex: 1;
    animation: fadeIn 1.2s ease;
}

.hero-text h1 {
    font-size: 48px;
}

.hero-img {
    flex: 1;
    text-align: center;
}

/* 👇 人物动态 */
.hero-img img {
    width: 80%;
    border-radius: 20px;
    animation: float 4s ease-in-out infinite;
}

/* 浮动动画 */
@keyframes float {
    0% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
    100% { transform: translateY(0); }
}

/* 渐入 */
@keyframes fadeIn {
    from { opacity: 0; transform: translateX(-50px); }
    to { opacity: 1; transform: translateX(0); }
}

/* 服务卡片 */
.services {
    text-align: center;
    padding: 80px;
}

.cards {
    display: flex;
    justify-content: center;
    gap: 30px;
    margin-top: 40px;
}

.card {
    background: #fff;
    padding: 40px;
    border-radius: 15px;
    width: 200px;
    transition: 0.3s;
}

/* 👇 悬浮效果 */
.card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}
